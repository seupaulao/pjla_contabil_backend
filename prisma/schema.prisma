// ==========================================================
// PLANO DE CONTAS REFERENCIAL
// ==========================================================

model PlanoContasReferencial {
  id                     Int       @id @default(autoincrement())
  codigo                 String
  nome                   String
  tipo                   String?
  natureza               String?
  nivel                  Int?
  grupo                  String?
  dreGrupo               String?  @map("dre_grupo")
  fluxoCaixaTipo         String?  @map("fluxo_caixa_tipo")
  createdAt              DateTime @default(now()) @map("created_at")
  excludedAt             DateTime? @map("excluded_at")
  parentId               Int? @map("parent_id")
  parent                 PlanoContasReferencial? @relation("PlanoRefHierarchy", fields: [parentId], references: [id])
  children               PlanoContasReferencial[] @relation("PlanoRefHierarchy")

  planoContas            PlanoContas[]

  @@map("plano_contas_referencial")
}

// ==========================================================
// PLANO DE CONTAS
// ==========================================================

model PlanoContas {
  id                          Int      @id @default(autoincrement())
  empresaId                   Int?     @map("empresa_id")
  planoContasReferencialId    Int?     @map("plano_contas_referencial_id")
  codigo                      String
  descricao                   String
  tipo                        String
  natureza                    String?
  nivel                       Int
  grupo                       String?
  subgrupo                    String?
  dreGrupo                    String?  @map("dre_grupo")
  fluxoCaixaTipo              String?  @map("fluxo_caixa_tipo")
  createdAt                   DateTime @default(now()) @map("created_at")
  excluidoAt                  DateTime? @map("excluido_at")

  contaPaiId                  Int? @map("conta_pai_id")

  empresa                     Empresa? @relation(fields: [empresaId], references: [id])
  planoReferencial            PlanoContasReferencial? @relation(fields: [planoContasReferencialId], references: [id])

  contaPai                    PlanoContas? @relation("PlanoContasHierarchy", fields: [contaPaiId], references: [id])
  subContas                   PlanoContas[] @relation("PlanoContasHierarchy")

  lancamentoItens             LancamentoItem[]
  // reportLineAccounts          ReportLineAccount[]
  mapaDemonstracoes           MapaDemonstracoes[]
  spedMappings                SpedMapping[]

  @@map("plano_contas")
}

// ==========================================================
// LANÇAMENTO
// ==========================================================

model Lancamento {
  id          Int       @id @default(autoincrement())
  empresaId   Int?      @map("empresa_id")
  data        DateTime  @db.Date
  historico   String?
  tipo        String    @default("N")
  createdAt   DateTime  @default(now()) @map("created_at")
  excluidoAt  DateTime? @map("excluido_at")

  empresa      Empresa? @relation(fields: [empresaId], references: [id])
  itens        LancamentoItem[]

  @@index([data], map: "idx_lancamento_data")
  @@map("lancamento")
}

model LancamentoItem {
  id               Int             @id @default(autoincrement())
  lancamentoId     Int?            @map("lancamento_id")
  contaId          Int?            @map("conta_id")
  tipo             LancamentoTipo
  valor            Decimal         @db.Decimal(14, 2)

  lancamento       Lancamento?     @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)
  conta            PlanoContas?    @relation(fields: [contaId], references: [id])

  tags             LancamentoItemTag[]

  @@index([contaId], map: "idx_lancamento_item_conta")
  @@map("lancamento_item")
}

