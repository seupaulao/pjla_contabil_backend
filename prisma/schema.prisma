// ==========================================================
// MAPA DEMONSTRAÇÕES
// ==========================================================

model MapaDemonstracoes {
  id           Int       @id @default(autoincrement())
  contaId      Int?      @map("conta_id")
  tipo         String?
  categoria    String?
  excluidoAt   DateTime? @map("excluido_at")

  conta        PlanoContas? @relation(fields: [contaId], references: [id])

  @@map("mapa_demonstracoes")
}

// ==========================================================
// TAGS
// ==========================================================

model Tag {
  id          String @id @default(uuid()) @db.Uuid
  empresaId   Int?   @map("empresa_id")
  name        String

  empresa      Empresa? @relation(fields: [empresaId], references: [id])
  lancamentos  LancamentoItemTag[]

  @@map("tags")
}

model LancamentoItemTag {
  lancamentoItemId Int    @map("lancamento_item_id")
  tagId            String @map("tag_id") @db.Uuid

  lancamentoItem   LancamentoItem @relation(fields: [lancamentoItemId], references: [id])
  tag              Tag @relation(fields: [tagId], references: [id])

  @@id([lancamentoItemId, tagId])
  @@map("lancamento_item_tags")
}

// ==========================================================
// SPED MAPPINGS
// ==========================================================

model SpedMapping {
  id           String @id @default(uuid()) @db.Uuid
  contaId      Int    @map("conta_id")
  spedCode     String @map("sped_code")
  description  String?

  conta        PlanoContas @relation(fields: [contaId], references: [id])

  @@map("sped_mappings")
}

// ==========================================================
// USUÁRIOS
// ==========================================================

model Usuario {
  id             String    @id @default(uuid()) @db.Uuid
  nome           String
  email          String    @unique
  passwordHash   String    @map("password_hash")
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  sessoes              UsuarioSessao[]
  empresas             EmpresaUsuario[]
  reportVersions       ReportVersion[]
  travaContabil        TravaContabil[]
  ecdArquivos          EcdArquivo[]
  assinaturasDigitais  AssinaturaDigital[]
  auditLogs            AuditLog[]

  @@map("usuarios")
}

// ==========================================================
// REGRAS / PERMISSÕES
// ==========================================================

model Regra {
  id      String @id @default(uuid()) @db.Uuid
  code    String @unique
  name    String

  permissoes      RegraPermissao[]
  empresaUsuarios EmpresaUsuario[]

  @@map("regras")
}

model Permissao {
  id          String @id @default(uuid()) @db.Uuid
  code        String @unique
  descricao   String?

  regras       RegraPermissao[]

  @@map("permissoes")
}

model RegraPermissao {
  roleId        String @map("role_id") @db.Uuid
  permissionId  String @map("permission_id") @db.Uuid

  role          Regra @relation(fields: [roleId], references: [id])
  permission    Permissao @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("regra_permissao")
}

model EmpresaUsuario {
  userId     String @map("user_id") @db.Uuid
  companyId  Int    @map("company_id")
  roleId     String? @map("role_id") @db.Uuid

  usuario    Usuario @relation(fields: [userId], references: [id])
  empresa    Empresa @relation(fields: [companyId], references: [id])
  regra      Regra? @relation(fields: [roleId], references: [id])

  @@id([userId, companyId])
  @@map("empresa_usuario")
}

// ==========================================================
// SESSÕES
// ==========================================================

model UsuarioSessao {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  token       String   @unique
  ipAddress   String?  @map("ip_address") @db.Inet
  userAgent   String?  @map("user_agent")
  expiresAt   DateTime @map("expires_at")
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  usuario     Usuario @relation(fields: [userId], references: [id])

  @@map("usuario_sessoes")
}

// ==========================================================
// AUDIT LOGS
// ==========================================================

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   Int?     @map("company_id")
  userId      String?  @map("user_id") @db.Uuid
  entityName  String?  @map("entity_name")
  entityId    String?  @map("entity_id")
  action      String?
  oldData     Json?    @map("old_data")
  newData     Json?    @map("new_data")
  createdAt   DateTime @default(now()) @map("created_at")

  empresa     Empresa? @relation(fields: [companyId], references: [id])
  usuario     Usuario? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ==========================================================
// SPED NATUREZA
// ==========================================================

model SpedNatureza {
  id           String @id @default(uuid()) @db.Uuid
  code         String @unique
  description  String

  @@map("sped_natureza")
}

// ==========================================================
// REPORT VERSIONS
// ==========================================================

model ReportVersion {
  id                String   @id @default(uuid()) @db.Uuid
  empresaId         Int      @map("empresa_id")
  reportTemplateId  String?  @map("report_template_id") @db.Uuid
  reportTypeId      String?  @map("report_type_id") @db.Uuid
  versionNumber     Int      @map("version_number")
  fiscalYear        Int      @map("fiscal_year")
  startPeriod       DateTime @map("start_period") @db.Date
  endPeriod         DateTime @map("end_period") @db.Date
  generatedBy       String?  @map("generated_by") @db.Uuid
  isLocked          Boolean  @default(false) @map("is_locked")
  notes             String?
  integrityHash     String?  @map("integrity_hash")
  createdAt         DateTime @default(now()) @map("created_at")

  empresa           Empresa @relation(fields: [empresaId], references: [id])
  // reportTemplate    ReportTemplate? @relation(fields: [reportTemplateId], references: [id])
  // reportType        ReportType? @relation(fields: [reportTypeId], references: [id])
  usuario           Usuario? @relation(fields: [generatedBy], references: [id])

  lines             ReportVersionLine[]

  @@map("report_versions")
}

model ReportVersionLine {
  id               String   @id @default(uuid()) @db.Uuid
  reportVersionId  String   @map("report_version_id") @db.Uuid
  lineOrder        Int?     @map("line_order")
  code             String?
  title            String?
  amount           Decimal? @db.Decimal(18, 2)
  createdAt        DateTime @default(now()) @map("created_at")

  reportVersion    ReportVersion @relation(fields: [reportVersionId], references: [id])

  @@map("report_version_lines")
}

// ==========================================================
// TRAVA CONTÁBIL
// ==========================================================

model TravaContabil {
  id          String    @id @default(uuid()) @db.Uuid
  empresaId   Int       @map("empresa_id")
  year        Int
  month       Int
  isClosed    Boolean   @default(false) @map("is_closed")
  closedBy    String?   @map("closed_by") @db.Uuid
  closedAt    DateTime? @map("closed_at")

  empresa     Empresa @relation(fields: [empresaId], references: [id])
  usuario     Usuario? @relation(fields: [closedBy], references: [id])

  @@map("trava_contabil")
}

// ==========================================================
// CERTIFICADOS DIGITAIS
// ==========================================================

model CertificadoDigital {
  id               String    @id @default(uuid()) @db.Uuid
  empresaId        Int       @map("empresa_id")
  certificateName  String?   @map("certificate_name")
  serialNumber     String?   @map("serial_number")
  validFrom        DateTime? @map("valid_from") @db.Date
  validUntil       DateTime? @map("valid_until") @db.Date
  issuer           String?
  encryptedPfx     Bytes?    @map("encrypted_pfx")
  createdAt        DateTime  @default(now()) @map("created_at")

  empresa          Empresa @relation(fields: [empresaId], references: [id])

  assinaturas      AssinaturaDigital[]

  @@map("certificados_digitais")
}

// ==========================================================
// ECD
// ==========================================================

model EcdArquivo {
  id            String    @id @default(uuid()) @db.Uuid
  empresaId     Int       @map("empresa_id")
  fiscalYear    Int       @map("fiscal_year")
  fileName      String?   @map("file_name")
  fileHash      String?   @map("file_hash")
  generatedBy   String?   @map("generated_by") @db.Uuid
  generatedAt   DateTime  @default(now()) @map("generated_at")
  signedAt      DateTime? @map("signed_at")
  deliveredAt   DateTime? @map("delivered_at")
  status        String?

  empresa       Empresa @relation(fields: [empresaId], references: [id])
  usuario       Usuario? @relation(fields: [generatedBy], references: [id])

  assinaturas   AssinaturaDigital[]

  @@map("ecd_arquivos")
}

model AssinaturaDigital {
  id              String   @id @default(uuid()) @db.Uuid
  ecdFileId       String   @map("ecd_file_id") @db.Uuid
  signedBy        String?  @map("signed_by") @db.Uuid
  certificateId   String?  @map("certificate_id") @db.Uuid
  signatureHash   String   @map("signature_hash")
  signedAt        DateTime @default(now()) @map("signed_at")

  ecdArquivo      EcdArquivo @relation(fields: [ecdFileId], references: [id])
  usuario         Usuario? @relation(fields: [signedBy], references: [id])
  certificado     CertificadoDigital? @relation(fields: [certificateId], references: [id])

  @@map("assinaturas_digitais")
}

// ==========================================================
// SPED ENTREGAS
// ==========================================================

model SpedEntrega {
  id             String    @id @default(uuid()) @db.Uuid
  empresaId      Int       @map("empresa_id")
  spedType       String?   @map("sped_type")
  fiscalYear     Int?      @map("fiscal_year")
  protocol       String?
  receiptNumber  String?   @map("receipt_number")
  deliveredAt    DateTime? @map("delivered_at")
  status         String?

  empresa        Empresa @relation(fields: [empresaId], references: [id])

  @@map("sped_entregas")
}

// ==========================================================
// JOBS
// ==========================================================

model Job {
  id           String    @id @default(uuid()) @db.Uuid
  queueName    String?   @map("queue_name")
  payload      Json?
  status       String    @default("PENDING")
  retries      Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  processedAt  DateTime? @map("processed_at")

  @@map("jobs")
}

// ==========================================================
// CONFIGURAÇÃO EMPRESA
// ==========================================================

model EmpresaConfiguracao {
  empresaId                     Int      @id @map("empresa_id")
  permitirDinheiroNegativo     Boolean  @default(false) @map("permitir_dinheiro_negativo")
  periodoFechamentoAutomatico  Boolean  @default(false) @map("periodo_fechamento_automatico")
  defaultReportTemplate        String?  @map("default_report_template") @db.Uuid
  createdAt                    DateTime @default(now()) @map("created_at")

  empresa        Empresa @relation(fields: [empresaId], references: [id])
  // reportTemplate ReportTemplate? @relation(fields: [defaultReportTemplate], references: [id])

  @@map("empresa_configuracao")
}
