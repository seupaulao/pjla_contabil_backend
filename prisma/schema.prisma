// ==========================================================
// PRISMA SCHEMA - CONTABILIDADE
// Convertido de PostgreSQL
// ==========================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================================
// ENUMS
// ==========================================================

enum LancamentoTipo {
  D
  C
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ==========================================================
// EMPRESA
// ==========================================================

model Empresa {
  id          Int       @id @default(autoincrement())
  cnpj        String
  nome        String
  uf          String?
  municipio   String?
  dataInicio  DateTime? @map("data_inicio") @db.Date
  dataFim     DateTime? @map("data_fim") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at")
  excluidoAt  DateTime? @map("excluido_at")

  planoContas              PlanoContas[]
  lancamentos              Lancamento[]
  // reportTemplates          ReportTemplate[]
  tags                     Tag[]
  reportVersions           ReportVersion[]
  travaContabil            TravaContabil[]
  certificadosDigitais     CertificadoDigital[]
  ecdArquivos              EcdArquivo[]
  spedEntregas             SpedEntrega[]
  configuracao             EmpresaConfiguracao?
  empresaUsuarios          EmpresaUsuario[]
  auditLogs                AuditLog[]

  @@map("empresa")
}

